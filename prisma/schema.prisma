// ============================================================================
//  Cortinería Nacional — Modelo de datos (Prisma + PostgreSQL)
// ----------------------------------------------------------------------------
//  Cubre toda la plataforma para no rehacer la estructura en fases futuras:
//  usuarios/roles, clientes, catálogo, cotizaciones, pedidos + seguimiento,
//  facturación, inventario, promociones, reseñas y auditoría.
//  Genera el cliente con:  npx prisma generate
//  Aplica el esquema con:  npx prisma db push   (o migrate dev)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
//  Autenticación y roles
// ---------------------------------------------------------------------------
enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(CUSTOMER)
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer      Customer?
  auditLogs     AuditLog[]
  favorites     Favorite[]
  notifications Notification[]
  passwordResets PasswordResetToken[]
}

// ---------------------------------------------------------------------------
//  Recuperación de contraseña (admin y cliente comparten la tabla User)
// ---------------------------------------------------------------------------
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * SHA-256 del token en claro. Nunca se guarda el token real: si alguien lee
   * la base, no puede reconstruir el enlace. El token viaja solo en el correo.
   */
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime? // se marca al consumirlo → un solo uso
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
//  Notificaciones internas (campana del panel)
// ---------------------------------------------------------------------------
enum NotificationType {
  COTIZACION
  PEDIDO
  ESTADO
}

model Notification {
  id        String           @id @default(cuid())
  // Destinatario. Se crea una fila por empleado para que cada uno marque como
  // leído por su cuenta sin afectar la bandeja de los demás.
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(COTIZACION)
  title     String
  body      String?
  /**
   * Ruta del panel a la que lleva la notificación (p. ej. /admin/cotizaciones).
   */
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
//  Clientes (clasificación automática por comportamiento)
// ---------------------------------------------------------------------------
enum CustomerType {
  POTENCIAL
  ACTIVO
  FRECUENTE
  INACTIVO
}

model Customer {
  id        String       @id @default(cuid())
  userId    String?      @unique
  user      User?        @relation(fields: [userId], references: [id])
  firstName String
  lastName  String
  email     String
  phone     String
  city      String?
  address   String?
  type      CustomerType @default(POTENCIAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  quotes   Quote[]
  orders   Order[]
  invoices Invoice[]

  @@index([email])
  @@index([type])
}

// ---------------------------------------------------------------------------
//  Catálogo
// ---------------------------------------------------------------------------
model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  shortDesc      String?
  description    String?
  fabric         String? // tipo de tela (texto libre: Blackout, Screen, Lino, PVC…)
  material       String?
  design         String? // diseño
  /**
   * Referencia comercial del diseño, texto libre: "Milan 502", "Roma 302".
   */
  designRef      String?
  /**
   * Si el cliente puede elegir de qué lado queda la cadenilla (el mando).
   * Apagado por defecto: los productos existentes siguen comportándose igual y
   * la opción no aparece en la compra hasta que el administrador la habilite.
   */
  allowChainSide Boolean   @default(false)
  colors         Json? // [{ name, hex }]
  pricePerMeter  Int? // en pesos (COP), null => cotiza tu medida
  price          Int?
  productionTime String?
  features       String[]
  gradient       String? // respaldo visual mientras no hay foto
  stock          Int       @default(0)
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  media ProductMedia[]

  @@index([categoryId])
  @@index([isActive])
}

enum MediaType {
  IMAGE
  VIDEO
}

model ProductMedia {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MediaType @default(IMAGE)
  url       String
  alt       String?
  sortOrder Int       @default(0)
}

// ---------------------------------------------------------------------------
//  Cotizaciones
// ---------------------------------------------------------------------------
enum QuoteStatus {
  NUEVA
  CONTACTADA
  CONVERTIDA
  DESCARTADA
}

model Quote {
  id          String      @id @default(cuid())
  code        String      @unique
  firstName   String
  lastName    String
  phone       String
  email       String
  city        String
  address     String
  productName String
  quantity    Int         @default(1)
  meters      Float?
  /**
   * Posición del mando elegida por el cliente: IZQUIERDA | DERECHA (ver lib/chain-side).
   */
  chainSide   String?
  comments    String?
  promoCode   String?
  discountPct Float?
  status      QuoteStatus @default(NUEVA)
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  order       Order?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([email])
}

// ---------------------------------------------------------------------------
//  Pedidos y seguimiento
// ---------------------------------------------------------------------------
enum OrderStatus {
  RECIBIDO
  FABRICACION
  CORTE
  CONFECCION
  DESPACHO
  INSTALACION
  FINALIZADO
  CANCELADO
}

model Order {
  id          String      @id @default(cuid())
  code        String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  quoteId     String?     @unique
  quote       Quote?      @relation(fields: [quoteId], references: [id])
  status      OrderStatus @default(RECIBIDO)
  total       Int         @default(0)
  installerId String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  history  OrderStatusHistory[]
  invoices Invoice[]

  @@index([status])
  @@index([customerId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

// ---------------------------------------------------------------------------
//  Facturación
// ---------------------------------------------------------------------------
model Invoice {
  id     String @id @default(cuid())
  number String @unique

  /**
   * Pedido de origen. Opcional desde el módulo de facturación: una factura
   * puede armarse directamente sobre el catálogo, sin pedido previo. Las
   * remisiones generadas desde un pedido siguen llegando con este campo.
   */
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  /**
   * Cliente facturado. Las remisiones antiguas lo derivan del pedido.
   */
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  /**
   * Totales, en pesos enteros (COP no usa centavos). Se guardan calculados
   * para que la factura sea un documento inmutable: si mañana cambia el precio
   * del producto, la factura ya emitida sigue diciendo lo mismo.
   */
  subtotal      Int @default(0) // suma de líneas, antes de descuentos e IVA
  discountTotal Int @default(0)
  extrasTotal   Int @default(0) // accesorios + instalación + transporte + recargos
  taxTotal      Int @default(0) // IVA
  /**
   * Total a pagar. Se conserva el nombre `amount` por compatibilidad.
   */
  amount        Int

  notes     String?
  pdfUrl    String?

  /**
   * Firma del cliente como data URI (`data:image/png;base64,…`).
   *
   * Se guarda EN LA BASE y no como archivo porque el disco de Vercel es de
   * solo lectura: un archivo en /public/uploads no sobrevive al despliegue.
   * Una firma pesa entre 5 y 30 KB, así que la columna es un sitio razonable
   * y además la vuelve parte inseparable del documento.
   */
  signature   String?
  /** Nombre de quien firma (puede no ser el titular de la factura). */
  signerName  String?
  signedAt    DateTime?

  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  items InvoiceItem[]

  @@index([customerId])
  @@index([issuedAt])
}

/**
 * Línea de una factura. Guarda una FOTO del producto en el momento de emitir
 * (nombre, referencia, tela) en vez de depender de la relación: si el producto
 * se edita o se borra del catálogo, la factura no cambia ni se rompe.
 */
model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  /**
   * Referencia al catálogo, sin borrado en cascada (puede quedar en null).
   */
  productId String?

  name      String
  designRef String?
  fabric    String?
  /**
   * Posición del mando: IZQUIERDA | DERECHA | null si no aplica.
   */
  chainSide String?
  widthM    Float?
  heightM   Float?

  quantity  Int @default(1)
  unitPrice Int @default(0)

  // Extras por producto (valores absolutos en COP, por línea).
  accessories  Int @default(0)
  installation Int @default(0)
  transport    Int @default(0)
  surcharge    Int @default(0) // recargos
  discount     Int @default(0) // descuento de la línea

  /**
   * IVA de la línea, en porcentaje (0 = exenta).
   */
  taxRate Float @default(0)

  notes String? // observaciones

  /**
   * Total de la línea ya calculado (cantidad · precio + extras − descuento + IVA).
   */
  lineTotal Int @default(0)
  sortOrder Int @default(0)

  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
//  Inventario
// ---------------------------------------------------------------------------
enum InventoryCategory {
  TELA
  MATERIAL
  ACCESORIO
  MOTOR
  INSUMO
}

model InventoryItem {
  id        String            @id @default(cuid())
  name      String
  category  InventoryCategory
  unit      String            @default("unidad")
  stock     Float             @default(0)
  minStock  Float             @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  movements InventoryMovement[]

  @@index([category])
}

enum MovementType {
  ENTRADA
  SALIDA
}

model InventoryMovement {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      MovementType
  quantity  Float
  reason    String?
  createdAt DateTime      @default(now())
}

// ---------------------------------------------------------------------------
//  Promociones (volantes)
// ---------------------------------------------------------------------------
model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  discountPct Float
  isActive    Boolean   @default(true)
  validUntil  DateTime?
  maxUses     Int?
  uses        Int       @default(0)
  createdAt   DateTime  @default(now())
}

// ---------------------------------------------------------------------------
//  Reseñas / testimonios
// ---------------------------------------------------------------------------
model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int      @default(5)
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
//  Favoritos del cliente
// ---------------------------------------------------------------------------
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// ---------------------------------------------------------------------------
//  Auditoría (accesos y acciones)
// ---------------------------------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // LOGIN, LOGOUT, CREATE, UPDATE, DELETE, DOWNLOAD, LOGIN_FAILED...
  entity    String? // p. ej. "Product", "Order"
  entityId  String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
//  Configuración del sitio (editable desde el panel, sin tocar código)
// ---------------------------------------------------------------------------
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
